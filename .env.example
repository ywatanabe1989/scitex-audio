# SciTeX Audio Environment Variables
# Copy to .env and fill in your values

# ElevenLabs API key (for elevenlabs backend)
# SCITEX_AUDIO_ELEVENLABS_API_KEY=your-api-key-here

# Audio mode: local, remote, or auto (default: auto)
# SCITEX_AUDIO_MODE=auto

# Relay server URL for remote playback
# SCITEX_AUDIO_RELAY_URL=http://localhost:31293

# Relay server host (alternative to full URL)
# SCITEX_AUDIO_RELAY_HOST=192.168.1.100

# Server port (default: 31293)
# SCITEX_AUDIO_PORT=31293

# LuxTTS reference audio path
# SCITEX_AUDIO_LUXTTS_REFERENCE=~/.config/scitex/audio/reference/my_voice.wav

# Debug mode
# SCITEX_AUDIO_DEBUG_MODE=1
